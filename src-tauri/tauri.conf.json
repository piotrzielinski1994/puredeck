{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "puredeck",
  "version": "0.1.0",
  "identifier": "com.pzielinski.puredeck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1433",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "puredeck",
        "width": 1000,
        "height": 700,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [{ "scheme": ["com.pzielinski.puredeck"], "appLink": false }]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
